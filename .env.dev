# ── Development Environment ──────────────────────────────────────
# Used by: docker-compose.yml when APP_ENV=dev
# Copy to .env.dev and fill in real values

APP_ENV=development
FLASK_ENV=development

# ── Security (dev — change in prod) ──────────────────────────────
SECRET_KEY=dev-secret-key-change-in-production
JWT_SECRET_KEY=dev-jwt-secret-change-in-production

# ── Database ──────────────────────────────────────────────────────
# When running in Docker, DATABASE_URL is overridden by docker-compose
# to point to the postgres container. This value is used for local dev.
DATABASE_URL=sqlite:///otpguard.db

# ── PostgreSQL (Docker) ───────────────────────────────────────────
POSTGRES_DB=otpguard
POSTGRES_USER=otpguard
POSTGRES_PASSWORD=otpguard_dev_secret
POSTGRES_PORT=5432

# ── Ports ─────────────────────────────────────────────────────────
BACKEND_PORT=5000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ── Email ─────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@otpguard.co.ke

# ── Twilio SMS ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Africa's Talking ──────────────────────────────────────────────
AT_API_KEY=your_at_api_key
AT_USERNAME=sandbox

# ── OTP ───────────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300

# ── CORS ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:80

# ── Logging & Monitoring ──────────────────────────────────────────
LOG_LEVEL=DEBUG
# Get DSN from https://sentry.io — leave blank to disable
SENTRY_DSN=
APP_VERSION=1.0.0-dev
