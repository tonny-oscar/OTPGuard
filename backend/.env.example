# ── Environment variables ── copy to .env and fill in your values ──

SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=jwt-secret-change-me
DEBUG=true

# Database (default: SQLite for dev, swap to PostgreSQL for prod)
DATABASE_URL=sqlite:///otpguard.db

# Email — use Gmail App Password (not your real password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@otpguard.co.ke

# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Africa's Talking SMS (Kenya)
AT_API_KEY=your_at_api_key
AT_USERNAME=sandbox

# OTP settings
OTP_EXPIRY_SECONDS=300

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Logging & Monitoring
LOG_LEVEL=DEBUG
SENTRY_DSN=
APP_VERSION=1.0.0-dev

# Monitoring Alert Channels (optional — leave blank to disable)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
PAGERDUTY_INTEGRATION_KEY=
